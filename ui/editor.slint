// Settings editor (Apps + Look tabs).
// The contract (in-properties + callbacks below) is what src/ui.rs wires; keep
// signatures stable. Everything else is private implementation.
//
// Slint-1.17 limitations honored here (see yield notes):
//  - no string substring/split -> installed-list filtering goes through the
//    pure `name-matches` callback (default handler shows all rows when the
//    Rust side leaves it unwired);
//  - shortcut combos captured in-session render pretty ("Ctrl + Shift + R"),
//    combos loaded from disk render raw ("ctrl+shift+r").

import { ListView, ScrollView } from "std-widgets.slint";
import { Skin } from "skin.slint";
import { AppRow, ActionRow, InstalledRow, IconPick } from "types.slint";

// ---------------------------------------------------------------- controls --

component GroupHead inherits Text {
    color: Skin.fg-dim;
    font-size: Skin.s(10);
    font-weight: 600;
    letter-spacing: Skin.s(1.5);
}

// Text input pill. Emits edited(text) on every user keystroke. External model
// updates are applied only while the field is unfocused, so typing never gets
// clobbered by the Rust round-trip.
component Field inherits Rectangle {
    in property <string> value;
    in property <string> placeholder;
    out property <string> text-value: ti.text;   // live text (for read-on-click uses)
    callback edited(string);

    height: Skin.s(30);
    min-width: Skin.s(60);
    border-radius: Skin.s(8);
    background: Skin.tint(0.06);
    border-width: 1px;
    border-color: ti.has-focus ? Skin.accent : Skin.tint(0.08);

    changed value => {
        if (!ti.has-focus) {
            ti.text = self.value;
        }
    }

    ti := TextInput {
        x: Skin.s(10);
        width: parent.width - Skin.s(20);
        height: parent.height;
        vertical-alignment: center;
        single-line: true;
        text: root.value;
        color: Skin.fg;
        font-size: Skin.s(12);
        edited => {
            root.edited(self.text);
        }
    }
    Text {
        x: Skin.s(10);
        width: parent.width - Skin.s(20);
        height: parent.height;
        vertical-alignment: center;
        visible: ti.text == "" && !ti.has-focus;
        text: root.placeholder;
        color: Skin.fg-dim;
        font-size: Skin.s(12);
    }
}

component PillBtn inherits Rectangle {
    in property <string> text;
    in property <bool> accent: false;
    callback clicked;

    height: Skin.s(32);
    min-width: txt.preferred-width + Skin.s(24);
    border-radius: Skin.s(9);
    background: root.accent
        ? (ta.has-hover ? Skin.accent.brighter(0.15) : Skin.accent)
        : (ta.has-hover ? Skin.tint(0.12) : Skin.tint(0.06));
    animate background { duration: 100ms; }

    txt := Text {
        width: 100%;
        height: 100%;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: root.text;
        color: root.accent ? #ffffff : Skin.fg;
        font-size: Skin.s(13);
        font-weight: 500;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// Small rainbow disc that opens the color picker for a target.
component PickBtn inherits Rectangle {
    callback clicked;
    width: Skin.s(22);
    height: Skin.s(22);
    border-radius: self.width / 2;
    background: @linear-gradient(135deg, #ff5555 0%, #ffb86c 25%, #50fa7b 50%, #8be9fd 75%, #bd93f9 100%);
    border-width: pk-ta.has-hover ? 2px : 1px;
    border-color: pk-ta.has-hover ? Skin.tint(0.9) : Skin.tint(0.35);
    pk-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component IconBtn inherits Rectangle {
    in property <string> glyph;
    in property <bool> enabled: true;
    callback clicked;

    width: Skin.s(28);
    height: Skin.s(28);
    border-radius: Skin.s(7);
    background: ta.has-hover && root.enabled ? Skin.tint(0.14) : Skin.tint(0.06);
    opacity: root.enabled ? 1 : 0.3;

    Text {
        width: 100%;
        height: 100%;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: root.glyph;
        color: Skin.fg;
        font-size: Skin.s(13);
    }
    ta := TouchArea {
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

component Toggle inherits Rectangle {
    in property <bool> on;
    callback toggled(bool);

    width: Skin.s(42);
    height: Skin.s(24);
    border-radius: self.height / 2;
    background: root.on ? Skin.accent : Skin.tint(0.15);
    animate background { duration: 120ms; }

    Rectangle {
        width: parent.height - Skin.s(4);
        height: parent.height - Skin.s(4);
        border-radius: self.height / 2;
        background: #ffffff;
        x: root.on ? parent.width - self.width - Skin.s(2) : Skin.s(2);
        y: Skin.s(2);
        animate x { duration: 130ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }
    }
    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.toggled(!root.on);
        }
    }
}

// Horizontal slider: track + accent fill + white handle. Emits moved(v) live
// on press and drag, snapped to `step` and clamped to [minimum, maximum].
component HSlider inherits Rectangle {
    in property <float> minimum: 0;
    in property <float> maximum: 1;
    in property <float> step: 1;
    in property <float> value: 0;
    callback moved(float);

    // live value: internal drag position while pressed, model value otherwise
    out property <float> live: ta.pressed
        ? self.drag-val
        : Math.clamp(root.value, root.minimum, root.maximum);

    private property <float> drag-val: root.value;
    private property <float> frac: (self.live - root.minimum) / (root.maximum - root.minimum);

    height: Skin.s(18);
    min-width: Skin.s(120);
    horizontal-stretch: 1;

    pure function snap(mx: length) -> float {
        return Math.clamp(
            root.minimum + Math.round(
                Math.clamp((mx - Skin.s(8)) / Math.max(root.width - Skin.s(16), 1px), 0, 1)
                    * (root.maximum - root.minimum) / root.step
            ) * root.step,
            root.minimum, root.maximum);
    }

    track := Rectangle {
        x: 0;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: Skin.s(4);
        border-radius: self.height / 2;
        background: Skin.tint(0.14);
    }
    Rectangle {
        x: 0;
        y: track.y;
        height: track.height;
        width: Skin.s(8) + root.frac * (parent.width - Skin.s(16));
        border-radius: track.border-radius;
        background: Skin.accent;
    }
    Rectangle {
        width: Skin.s(16);
        height: Skin.s(16);
        border-radius: self.width / 2;
        x: root.frac * (parent.width - self.width);
        y: (parent.height - self.height) / 2;
        background: #ffffff;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.drag-val = root.snap(self.mouse-x);
                root.moved(root.drag-val);
            }
        }
        moved => {
            root.drag-val = root.snap(self.mouse-x);
            root.moved(root.drag-val);
        }
    }
}

// Vertical scroll area with an always-visible scrollbar when content
// overflows (std ScrollView only hints on hover).
component VScroll inherits Rectangle {
    sv := ScrollView {
        width: parent.width;
        height: parent.height;
        @children
    }
    // hit zone is s(14) wide; the visible bar is a slim right-aligned strip
    if sv.viewport-height > sv.visible-height: Rectangle {
        x: parent.width - Skin.s(14);
        width: Skin.s(14);
        height: parent.height;
        Rectangle {
            x: parent.width - Skin.s(4);
            width: Skin.s(3);
            height: parent.height;
            border-radius: Skin.s(2);
            background: Skin.tint(0.06);
            vs-thumb := Rectangle {
                width: parent.width;
                height: Math.max(parent.height * sv.visible-height / sv.viewport-height, Skin.s(24));
                y: (parent.height - self.height)
                    * Math.clamp(-sv.viewport-y / Math.max(sv.viewport-height - sv.visible-height, 1px), 0, 1);
                border-radius: parent.border-radius;
                background: vs-ta.has-hover || vs-ta.pressed ? Skin.tint(0.5) : Skin.tint(0.25);
            }
        }
        vs-ta := TouchArea {
            pointer-event(e) => {
                if (self.pressed || e.kind == PointerEventKind.down) {
                    sv.viewport-y = -Math.clamp(
                        (self.mouse-y - vs-thumb.height / 2) / Math.max(parent.height - vs-thumb.height, 1px),
                        0, 1) * (sv.viewport-height - sv.visible-height);
                }
            }
        }
    }
}

// One-line compact slider row: small label, slim slider, value readout.
component CompactSlider inherits HorizontalLayout {
    in property <string> label;
    in property <length> label-w: Skin.s(100);
    in property <string> suffix: "px";
    in property <float> minimum;
    in property <float> maximum;
    in property <float> step: 1;
    in property <float> value;
    in property <float> display-mul: 1;    // 100 for % readouts
    callback changed(float);

    spacing: Skin.s(10);
    height: Skin.s(26);
    Text {
        width: root.label-w;
        text: root.label;
        color: Skin.fg;
        font-size: Skin.s(12);
        vertical-alignment: center;
        overflow: elide;
    }
    csl := HSlider {
        minimum: root.minimum;
        maximum: root.maximum;
        step: root.step;
        value: root.value;
        moved(v) => {
            root.changed(v);
        }
    }
    Text {
        width: Skin.s(42);
        text: "\{Math.round(csl.live * root.display-mul)}\{root.suffix}";
        color: Skin.fg-dim;
        font-size: Skin.s(11);
        vertical-alignment: center;
        horizontal-alignment: right;
    }
}

// Grouped settings section: rounded faint card with a header.
component Card inherits Rectangle {
    in property <string> title;
    border-radius: Skin.s(12);
    background: Skin.tint(0.035);
    border-width: 1px;
    border-color: Skin.tint(0.07);
    VerticalLayout {
        padding: Skin.s(12);
        spacing: Skin.s(8);
        GroupHead { text: root.title; }
        @children
    }
}

// Labeled pill toggle for a compact toggles row.
component ToggleChip inherits Rectangle {
    in property <string> label;
    in property <bool> on;
    callback toggled(bool);

    height: Skin.s(28);
    width: chip-l.preferred-width + Skin.s(26);
    border-radius: self.height / 2;
    background: root.on ? Skin.accent.with-alpha(0.2) : Skin.tint(0.06);
    border-width: 1px;
    border-color: root.on ? Skin.accent : Skin.tint(0.10);
    animate background, border-color { duration: 120ms; }
    chip-l := Text {
        x: Skin.s(13);
        height: 100%;
        text: root.label;
        color: root.on ? Skin.fg-strong : Skin.fg-dim;
        font-size: Skin.s(12);
        vertical-alignment: center;
    }
    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.toggled(!root.on);
        }
    }
}

// Key-combo capture cell. Click -> focused recording state; first non-modifier
// key press is encoded (lowercase, '+'-joined, modifier order ctrl,alt,shift,
// super) and emitted via captured(). Escape or focus loss cancels.
component ShortcutRecorder inherits Rectangle {
    in property <string> value;
    callback captured(string);

    private property <bool> recording: false;
    private property <string> scratch;        // encoded key of current event
    private property <string> last-captured;  // combo captured this session…
    private property <string> last-pretty;    // …and its pretty rendering

    width: Skin.s(150);
    height: Skin.s(30);
    border-radius: Skin.s(8);
    background: self.recording ? Skin.tint(0.14) : Skin.tint(0.06);
    border-width: 1px;
    border-color: self.recording ? Skin.accent : Skin.tint(0.08);

    // Slint Key code / char -> Hyprland keysym name ("" = ignore, keep waiting)
    pure function enc-key(t: string) -> string {
        if (t == Key.Control || t == Key.ControlR || t == Key.Shift || t == Key.ShiftR
            || t == Key.Alt || t == Key.AltGr || t == Key.Meta || t == Key.MetaR
            || t == Key.CapsLock) { return ""; }
        if (t == Key.Return) { return "return"; }
        if (t == Key.Space) { return "space"; }
        if (t == Key.Tab || t == Key.Backtab) { return "tab"; }
        if (t == Key.Backspace) { return "backspace"; }
        if (t == Key.Delete) { return "delete"; }
        if (t == Key.Home) { return "home"; }
        if (t == Key.End) { return "end"; }
        if (t == Key.PageUp) { return "prior"; }
        if (t == Key.PageDown) { return "next"; }
        if (t == Key.LeftArrow) { return "left"; }
        if (t == Key.RightArrow) { return "right"; }
        if (t == Key.UpArrow) { return "up"; }
        if (t == Key.DownArrow) { return "down"; }
        if (t == Key.F1) { return "F1"; }
        if (t == Key.F2) { return "F2"; }
        if (t == Key.F3) { return "F3"; }
        if (t == Key.F4) { return "F4"; }
        if (t == Key.F5) { return "F5"; }
        if (t == Key.F6) { return "F6"; }
        if (t == Key.F7) { return "F7"; }
        if (t == Key.F8) { return "F8"; }
        if (t == Key.F9) { return "F9"; }
        if (t == Key.F10) { return "F10"; }
        if (t == Key.F11) { return "F11"; }
        if (t == Key.F12) { return "F12"; }
        if (t == ",") { return "comma"; }
        if (t == ".") { return "period"; }
        if (t == "/") { return "slash"; }
        if (t == ";") { return "semicolon"; }
        if (t == "-") { return "minus"; }
        if (t == "=") { return "equal"; }
        if (t == Key.Insert || t == Key.ScrollLock || t == Key.Pause
            || t == Key.SysReq || t == Key.Stop || t == Key.Menu
            || t == Key.Escape) { return ""; }
        if (t.character-count == 1) { return t.to-lowercase(); }
        return "";
    }

    pure function pretty-key(k: string) -> string {
        if (k.character-count == 1) { return k.to-uppercase(); }
        if (k == "return") { return "Return"; }
        if (k == "space") { return "Space"; }
        if (k == "tab") { return "Tab"; }
        if (k == "backspace") { return "Backspace"; }
        if (k == "delete") { return "Delete"; }
        if (k == "home") { return "Home"; }
        if (k == "end") { return "End"; }
        if (k == "prior") { return "PgUp"; }
        if (k == "next") { return "PgDn"; }
        if (k == "left") { return "Left"; }
        if (k == "right") { return "Right"; }
        if (k == "up") { return "Up"; }
        if (k == "down") { return "Down"; }
        if (k == "comma") { return "Comma"; }
        if (k == "period") { return "Period"; }
        if (k == "slash") { return "Slash"; }
        if (k == "semicolon") { return "Semicolon"; }
        if (k == "minus") { return "Minus"; }
        if (k == "equal") { return "Equal"; }
        return k;
    }

    Text {
        width: 100%;
        height: 100%;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
        text: root.recording ? "Press keys…"
            : root.value == "" ? "Click to set"
            : (root.value == root.last-captured ? root.last-pretty : root.value);
        color: root.recording || root.value != "" ? Skin.fg : Skin.fg-dim;
        font-size: Skin.s(12);
    }

    fs := FocusScope {
        width: 100%;
        height: 100%;
        changed has-focus => {
            if (!self.has-focus) {
                root.recording = false;
            }
        }
        key-pressed(event) => {
            if (!root.recording) {
                return reject;
            }
            if (event.text == Key.Escape) {
                root.recording = false;
                return accept;
            }
            root.scratch = root.enc-key(event.text);
            if (root.scratch == "") {
                return accept; // lone modifier / unmappable: keep waiting
            }
            root.last-captured =
                (event.modifiers.control ? "ctrl+" : "")
                + (event.modifiers.alt ? "alt+" : "")
                + (event.modifiers.shift ? "shift+" : "")
                + (event.modifiers.meta ? "super+" : "")
                + root.scratch;
            root.last-pretty =
                (event.modifiers.control ? "Ctrl + " : "")
                + (event.modifiers.alt ? "Alt + " : "")
                + (event.modifiers.shift ? "Shift + " : "")
                + (event.modifiers.meta ? "Super + " : "")
                + root.pretty-key(root.scratch);
            root.recording = false;
            root.captured(root.last-captured);
            return accept;
        }
    }
    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.recording = true;
            fs.focus();
        }
    }
}

// Row with a fixed-width leading label.
component SettingRow inherits HorizontalLayout {
    in property <string> label;
    in property <length> label-width: Skin.s(120);
    spacing: Skin.s(12);
    Text {
        width: root.label-width;
        text: root.label;
        color: Skin.fg;
        font-size: Skin.s(13);
        vertical-alignment: center;
        overflow: elide;
    }
    @children
}

// ------------------------------------------------------------------ editor --

export component Editor {
    // ---- models (owned + refreshed by Rust) ----
    in property <[AppRow]> apps;
    in property <int> selected-app: -1;
    in property <[ActionRow]> app-actions;     // actions of the selected app
    in property <[InstalledRow]> installed;    // app picker rows (Rust-filtered)
    in property <[IconPick]> icon-picks;       // icon picker results (Rust-filtered)
    in property <int> icon-lib-count;          // 0 -> show the "no library" hint
    in property <[string]> themes;
    in property <string> current-theme;

    // ---- Look-tab mirrors ----
    in property <string> accent-hex;
    in property <string> bg-hex;
    in property <float> icon-size;
    in property <float> ring-radius;
    in property <float> dim;
    in property <float> wheel-opacity;
    in property <bool> show-labels;
    in property <bool> follow-outside;
    in property <float> hole-size;
    in property <bool> show-dots;
    // section geometry (design px) + inactive-section fill
    in property <float> sector-radius;
    in property <float> seg-radius;
    in property <float> section-inset;
    in property <float> seg-gap;
    in property <string> seg-bg-hex;

    // ---- shortcuts ----
    in property <bool> shortcuts-enabled;
    in property <bool> persist-binds;
    in property <string> sc-apps;
    in property <string> sc-windows;
    in property <string> sc-actions;
    in property <bool> can-manage-keybinds;    // false -> show bind-it-yourself hint
    in property <bool> can-send-keys;          // false -> custom key-combo actions warn

    // ---- callbacks into Rust ----
    callback select-app(int);
    callback add-app();                        // blank manual entry
    callback add-installed(int);               // index into `installed`
    callback remove-app(int);
    callback move-app(int, int);               // (index, dir: -1|+1)
    callback reorder-app(int, int);            // drag & drop: (from index, to index)
    callback set-app-field(int, string, string);   // (index, "name"|"icon"|"exec"|"wmClass", value)
    callback toggle-action(string, bool);      // (action id, enabled) for selected app
    callback add-custom-action();
    callback remove-custom-action(string);     // action id ("c:<k>")
    callback set-custom-field(string, string, string); // (id, "label"|"shortcut"|"icon"|"color", value)
    callback set-setting(string, string);      // stringly: ("iconSize","54"), ("showLabels","true"), ("accent","#..."), ("theme","nord")
    callback set-shortcut(string, string);     // (mode, combo) combo lowercase '+'-joined
    callback reset-settings();
    callback close-requested();
    // snapshot the current effective look into ~/.config/radiall/themes/<name>.json
    callback save-theme(string);

    // Rust filters the installed list / icon library on these queries and
    // re-pushes the `installed` / `icon-picks` models (Slint has no string
    // `contains`, and Rust-side filtering keeps original indices intact).
    callback pick-query(string);
    callback icon-query(string);

    // color picker: open-picker(target, current-hex) -> Rust seeds the HSV
    // props below and sets picker-for; drags emit color-picked live.
    // Targets: "accent" | "bg" | "segBg" | "app:<idx>" | "act:<action-id>".
    callback open-picker(string, string);
    callback color-picked(string, float, float, float, float);
    // icon picker selection: (target "app:<idx>" | "act:<id>", icon name or path)
    callback icon-picked(string, string);
    in-out property <string> picker-for: "";
    in-out property <float> picker-h: 0;
    in-out property <float> picker-s: 1;
    in-out property <float> picker-v: 1;
    in-out property <float> picker-a: 1;

    // ---- private state ----
    private property <int> cur-tab: 0;             // 0 = Apps, 1 = Look
    private property <bool> picking: false;        // installed-app picker overlay
    private property <int> drag-from: -1;          // app-list drag & drop source
    private property <int> drag-to: -1;            // ...and current drop target
    private property <string> picking-icon-for: "";  // action id, "" = icon picker closed
    private property <bool> sel-ok: root.selected-app >= 0 && root.selected-app < root.apps.length;

    // custom-action color swatches (parallel arrays; "" = theme default)
    private property <[color]>  action-cols: [#e44854, #0a84ff, #ffd60a, #30d158, #ff9f0a, #bf5af2, #64d2ff, #00000000];
    private property <[string]> action-hex:  ["#e44854", "#0a84ff", "#ffd60a", "#30d158", "#ff9f0a", "#bf5af2", "#64d2ff", ""];
    // Look-tab presets
    private property <[color]>  accent-cols: [#e44854, #0a84ff, #5e5ce6, #bf5af2, #ff9f0a, #30d158, #64d2ff, #ff2d55];
    private property <[string]> accent-hexes: ["#e44854", "#0a84ff", "#5e5ce6", "#bf5af2", "#ff9f0a", "#30d158", "#64d2ff", "#ff2d55"];
    private property <[color]>  bg-cols: [#0b0b0d, #1c1c22, #2b2b30, #46464f, #c9d8ef, #dbe4f2, #e8e3d5, #ffffff];
    private property <[string]> bg-hexes: ["#0b0b0d", "#1c1c22", "#2b2b30", "#46464f", "#c9d8ef", "#dbe4f2", "#e8e3d5", "#ffffff"];
    // NOTE slint hex literals are #RRGGBBAA (alpha LAST); the strings sent to
    // Rust stay QML-style #AARRGGBB (alpha first).
    private property <[color]>  seg-cols: [#ffffff14, #ffffff26, #ffffff40, #00000014, #00000026, #00000040];
    private property <[string]> seg-hexes: ["#14ffffff", "#26ffffff", "#40ffffff", "#14000000", "#26000000", "#40000000"];

    min-width: Skin.s(480);
    horizontal-stretch: 1;
    vertical-stretch: 1;

    // focus sink: steals keyboard focus from text fields before selection
    // changes so external model updates can refresh them (see Field).
    blur := FocusScope {
        width: 0;
        height: 0;
    }

    panel := Rectangle {
        border-radius: Skin.s(20);
        background: Skin.panel-bg;
        border-width: 1px;
        border-color: Skin.tint(0.10);

        VerticalLayout {
            padding: Skin.s(16);
            spacing: Skin.s(12);

            // ------------------------------------------------- header: tabs
            HorizontalLayout {
                Rectangle {
                    width: Skin.s(148);
                    height: Skin.s(34);
                    border-radius: Skin.s(9);
                    background: Skin.tint(0.06);
                    HorizontalLayout {
                        padding: Skin.s(4);
                        for tab-label[t-idx] in ["Apps", "Look"]: Rectangle {
                            width: Skin.s(70);
                            border-radius: Skin.s(7);
                            background: root.cur-tab == t-idx ? Skin.accent : transparent;
                            animate background { duration: 130ms; }
                            Text {
                                width: 100%;
                                height: 100%;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                text: tab-label;
                                color: root.cur-tab == t-idx ? #ffffff : Skin.fg;
                                font-size: Skin.s(12);
                                font-weight: 500;
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    blur.focus();
                                    root.cur-tab = t-idx;
                                }
                            }
                        }
                    }
                }
                Rectangle { } // spacer
                // close (same as Done: saves pending edits and hides)
                Rectangle {
                    width: Skin.s(34);
                    height: Skin.s(34);
                    border-radius: Skin.s(9);
                    background: x-ta.has-hover ? Skin.red.with-alpha(0.18) : Skin.tint(0.06);
                    border-width: 1px;
                    border-color: x-ta.has-hover ? Skin.red : Skin.tint(0.10);
                    animate background, border-color { duration: 120ms; }
                    Text {
                        width: 100%;
                        height: 100%;
                        text: "✕";
                        color: x-ta.has-hover ? Skin.red : Skin.fg;
                        font-size: Skin.s(14);
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    x-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.close-requested();
                        }
                    }
                }
            }

            // ------------------------------------------------------ content
            Rectangle {
                vertical-stretch: 1;

                // ================================================= APPS tab
                HorizontalLayout {
                    visible: root.cur-tab == 0;
                    spacing: Skin.s(12);

                    // ---- left: app list + add buttons
                    VerticalLayout {
                        width: Skin.s(225);
                        spacing: Skin.s(8);

                        ListView {
                            vertical-stretch: 1;
                            for app[i] in root.apps: Rectangle {
                                height: Skin.s(46);
                                // drop indicator: accent line above/below the
                                // target row (insertion side depends on drag
                                // direction), drawn per-row so it survives
                                // ListView virtualization
                                if root.drag-from >= 0 && root.drag-to == i && root.drag-to < root.drag-from: Rectangle {
                                    y: 0;
                                    width: parent.width - Skin.s(6);
                                    height: 2px;
                                    background: Skin.accent;
                                }
                                if root.drag-from >= 0 && root.drag-to == i && root.drag-to > root.drag-from: Rectangle {
                                    y: parent.height - 2px;
                                    width: parent.width - Skin.s(6);
                                    height: 2px;
                                    background: Skin.accent;
                                }
                                Rectangle {
                                    y: Skin.s(2);
                                    width: parent.width - Skin.s(6);
                                    height: Skin.s(42);
                                    border-radius: Skin.s(10);
                                    opacity: root.drag-from == i ? 0.45 : 1.0;
                                    background: i == root.selected-app
                                        ? Skin.tint(0.09)
                                        : (app-ta.has-hover ? Skin.tint(0.07) : Skin.tint(0.035));
                                    border-width: i == root.selected-app ? 1px : 0;
                                    border-color: Skin.accent;
                                    HorizontalLayout {
                                        padding-left: Skin.s(10);
                                        padding-right: Skin.s(8);
                                        spacing: Skin.s(8);
                                        Rectangle {
                                            width: Skin.s(26);
                                            if app.has-icon: Image {
                                                width: Skin.s(26);
                                                height: Skin.s(26);
                                                y: (parent.height - self.height) / 2;
                                                source: app.icon;
                                                image-fit: contain;
                                            }
                                            if !app.has-icon: Rectangle {
                                                width: Skin.s(26);
                                                height: Skin.s(26);
                                                y: (parent.height - self.height) / 2;
                                                border-radius: Skin.s(6);
                                                background: Skin.tint(0.10);
                                            }
                                        }
                                        Text {
                                            text: app.name;
                                            color: Skin.fg;
                                            font-size: Skin.s(13);
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                        // grip hint: rows are draggable
                                        Text {
                                            text: "≡";
                                            color: app-ta.has-hover ? Skin.tint(0.45) : Skin.tint(0.18);
                                            font-size: Skin.s(13);
                                            vertical-alignment: center;
                                        }
                                    }
                                    app-ta := TouchArea {
                                        private property <length> press-y;
                                        mouse-cursor: root.drag-from == i ? MouseCursor.grabbing : MouseCursor.pointer;
                                        clicked => {
                                            blur.focus();
                                            root.select-app(i);
                                        }
                                        pointer-event(e) => {
                                            if (e.kind == PointerEventKind.down) {
                                                self.press-y = self.mouse-y;
                                            } else if (e.kind == PointerEventKind.move && self.pressed) {
                                                // lift after a small threshold, then track the slot
                                                if (root.drag-from == -1 && Math.abs((self.mouse-y - self.press-y) / 1px) > Skin.s(6) / 1px) {
                                                    root.drag-from = i;
                                                }
                                                if (root.drag-from == i) {
                                                    root.drag-to = Math.clamp(
                                                        i + Math.round((self.mouse-y - Skin.s(46) / 2) / Skin.s(46)),
                                                        0, root.apps.length - 1);
                                                }
                                            } else if (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) {
                                                if (root.drag-from == i && root.drag-to >= 0 && root.drag-to != i) {
                                                    root.reorder-app(i, root.drag-to);
                                                }
                                                root.drag-from = -1;
                                                root.drag-to = -1;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        PillBtn {
                            text: "Add app";
                            accent: true;
                            clicked => {
                                root.add-app();
                            }
                        }
                        PillBtn {
                            text: "From installed…";
                            clicked => {
                                root.pick-query("");   // reset the Rust-side filter
                                root.picking = true;
                            }
                        }
                    }

                    // ---- right: selected-app editor + actions
                    Rectangle {
                        background: Skin.tint(0.035);
                        border-radius: Skin.s(12);
                        border-width: 1px;
                        border-color: Skin.tint(0.07);

                        if !root.sel-ok: Text {
                            width: 100%;
                            height: 100%;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            text: root.apps.length == 0
                                ? "No apps yet — add one on the left"
                                : "Select an app to edit";
                            color: Skin.fg-dim;
                            font-size: Skin.s(13);
                        }

                        if root.sel-ok: ScrollView {
                            VerticalLayout {
                                alignment: start;   // keep rows at the top, don't distribute slack
                                padding: Skin.s(14);
                                spacing: Skin.s(9);

                                HorizontalLayout {
                                    spacing: Skin.s(6);
                                    GroupHead {
                                        text: "APP";
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    IconBtn {
                                        glyph: "↑";
                                        enabled: root.selected-app > 0;
                                        clicked => {
                                            root.move-app(root.selected-app, -1);
                                        }
                                    }
                                    IconBtn {
                                        glyph: "↓";
                                        enabled: root.selected-app < root.apps.length - 1;
                                        clicked => {
                                            root.move-app(root.selected-app, 1);
                                        }
                                    }
                                    Rectangle {
                                        width: 1px;
                                        height: Skin.s(20);
                                        y: (parent.height - self.height) / 2;
                                        background: Skin.tint(0.10);
                                    }
                                    // delete: red, unmistakable
                                    Rectangle {
                                        width: Skin.s(30);
                                        height: Skin.s(28);
                                        border-radius: Skin.s(8);
                                        background: del-ta.has-hover ? Skin.red : Skin.red.with-alpha(0.75);
                                        animate background { duration: 120ms; }
                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: "\u{f1f8}";
                                            font-family: Skin.icon-font;
                                            color: white;
                                            font-size: Skin.s(13);
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        del-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.remove-app(root.selected-app);
                                            }
                                        }
                                    }
                                }

                                SettingRow {
                                    label: "Name";
                                    label-width: Skin.s(64);
                                    Field {
                                        value: root.apps[root.selected-app].name;
                                        edited(t) => {
                                            root.set-app-field(root.selected-app, "name", t);
                                        }
                                    }
                                }
                                SettingRow {
                                    label: "Icon";
                                    label-width: Skin.s(64);
                                    Field {
                                        value: root.apps[root.selected-app].icon-name;
                                        placeholder: "icon name or /abs/path";
                                        edited(t) => {
                                            root.set-app-field(root.selected-app, "icon", t);
                                        }
                                    }
                                    PillBtn {
                                        text: "Browse…";
                                        clicked => {
                                            root.icon-query("");
                                            root.picking-icon-for = "app:\{root.selected-app}";
                                        }
                                    }
                                }
                                SettingRow {
                                    label: "Command";
                                    label-width: Skin.s(64);
                                    Field {
                                        value: root.apps[root.selected-app].exec;
                                        placeholder: "command args";
                                        edited(t) => {
                                            root.set-app-field(root.selected-app, "exec", t);
                                        }
                                    }
                                }
                                SettingRow {
                                    label: "Class";
                                    label-width: Skin.s(64);
                                    Field {
                                        value: root.apps[root.selected-app].wm-class;
                                        placeholder: "window class";
                                        edited(t) => {
                                            root.set-app-field(root.selected-app, "wmClass", t);
                                        }
                                    }
                                }
                                SettingRow {
                                    label: "Accent";
                                    label-width: Skin.s(64);
                                    HorizontalLayout {
                                        spacing: Skin.s(6);
                                        alignment: start;
                                        // per-app wedge/dot color; "" = theme default
                                        for chex[k] in root.action-hex: Rectangle {
                                            width: Skin.s(22);
                                            height: Skin.s(22);
                                            border-radius: self.width / 2;
                                            background: root.action-cols[k];
                                            border-width: root.apps[root.selected-app].color.to-lowercase() == chex ? 2px : 1px;
                                            border-color: root.apps[root.selected-app].color.to-lowercase() == chex
                                                ? Skin.tint(0.9)
                                                : Skin.tint(0.3);
                                            if chex == "": Rectangle {
                                                width: Skin.s(8);
                                                height: Skin.s(8);
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: self.width / 2;
                                                border-width: 1px;
                                                border-color: Skin.tint(0.5);
                                            }
                                            TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.set-app-field(root.selected-app, "color", chex);
                                                }
                                            }
                                        }
                                        PickBtn {
                                            clicked => {
                                                root.open-picker("app:\{root.selected-app}", root.apps[root.selected-app].color);
                                            }
                                        }
                                    }
                                }

                                Rectangle { height: Skin.s(4); }
                                GroupHead { text: "ACTIONS"; }

                                if !root.can-send-keys: Text {
                                    text: "No key injection on this compositor — key-combo actions launch the app instead.";
                                    color: Skin.fg-dim;
                                    font-size: Skin.s(11);
                                    wrap: word-wrap;
                                }

                                for a[j] in root.app-actions: Rectangle {
                                    height: a.is-custom ? Skin.s(154) : Skin.s(44);

                                    Rectangle {
                                        width: parent.width;
                                        height: parent.height - Skin.s(4);
                                        border-radius: Skin.s(8);
                                        background: Skin.tint(0.05);

                                        // -- template action: glyph + label + toggle
                                        if !a.is-custom: HorizontalLayout {
                                            padding-left: Skin.s(10);
                                            padding-right: Skin.s(10);
                                            padding-top: (Skin.s(40) - Skin.s(24)) / 2;
                                            padding-bottom: (Skin.s(40) - Skin.s(24)) / 2;
                                            spacing: Skin.s(8);
                                            Text {
                                                width: Skin.s(22);
                                                text: a.glyph;
                                                font-family: Skin.icon-font;
                                                font-size: Skin.s(15);
                                                color: Skin.fg;
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: a.label;
                                                color: Skin.fg;
                                                font-size: Skin.s(13);
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            Toggle {
                                                on: a.enabled;
                                                toggled(v) => {
                                                    root.toggle-action(a.id, v);
                                                }
                                            }
                                        }

                                        // -- custom action: label / shortcut / icon / color
                                        if a.is-custom: VerticalLayout {
                                            padding: Skin.s(10);
                                            spacing: Skin.s(8);
                                            HorizontalLayout {
                                                spacing: Skin.s(8);
                                                Text {
                                                    width: Skin.s(22);
                                                    text: "\u{f084}";
                                                    font-family: Skin.icon-font;
                                                    font-size: Skin.s(14);
                                                    color: Skin.fg-dim;
                                                    vertical-alignment: center;
                                                }
                                                Field {
                                                    value: a.label;
                                                    placeholder: "label";
                                                    edited(t) => {
                                                        root.set-custom-field(a.id, "label", t);
                                                    }
                                                }
                                                IconBtn {
                                                    glyph: "✕";
                                                    clicked => {
                                                        root.remove-custom-action(a.id);
                                                    }
                                                }
                                            }
                                            HorizontalLayout {
                                                spacing: Skin.s(8);
                                                ShortcutRecorder {
                                                    value: a.shortcut;
                                                    captured(s) => {
                                                        root.set-custom-field(a.id, "shortcut", s);
                                                    }
                                                }
                                                Field {
                                                    value: a.icon-name;
                                                    placeholder: "icon name or /path.svg";
                                                    edited(t) => {
                                                        root.set-custom-field(a.id, "icon", t);
                                                    }
                                                }
                                                PillBtn {
                                                    text: "Browse…";
                                                    clicked => {
                                                        root.icon-query("");
                                                        root.picking-icon-for = "act:\{a.id}";
                                                    }
                                                }
                                            }
                                            HorizontalLayout {
                                                spacing: Skin.s(6);
                                                alignment: start;
                                                for chex[k] in root.action-hex: Rectangle {
                                                    width: Skin.s(22);
                                                    height: Skin.s(22);
                                                    border-radius: self.width / 2;
                                                    background: root.action-cols[k];
                                                    border-width: a.color.to-lowercase() == chex ? 2px : 1px;
                                                    border-color: a.color.to-lowercase() == chex
                                                        ? Skin.tint(0.9)
                                                        : Skin.tint(0.3);
                                                    // "" swatch: theme-default hint ring
                                                    if chex == "": Rectangle {
                                                        width: Skin.s(8);
                                                        height: Skin.s(8);
                                                        x: (parent.width - self.width) / 2;
                                                        y: (parent.height - self.height) / 2;
                                                        border-radius: self.width / 2;
                                                        border-width: 1px;
                                                        border-color: Skin.tint(0.5);
                                                    }
                                                    TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => {
                                                            root.set-custom-field(a.id, "color", chex);
                                                        }
                                                    }
                                                }
                                                PickBtn {
                                                    clicked => {
                                                        root.open-picker("act:\{a.id}", a.color);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                PillBtn {
                                    text: "Add custom action";
                                    clicked => {
                                        root.add-custom-action();
                                    }
                                }
                            }
                        }
                    }
                }

                // ================================================= LOOK tab
                VScroll {
                    visible: root.cur-tab == 1;

                    VerticalLayout {
                        padding: Skin.s(4);
                        padding-right: Skin.s(12);
                        spacing: Skin.s(10);

                        Card {
                            title: "THEME";
                            HorizontalLayout {
                                spacing: Skin.s(8);
                                theme-btn := Rectangle {
                            horizontal-stretch: 1;
                            height: Skin.s(32);
                            border-radius: Skin.s(8);
                            background: tb-ta.has-hover ? Skin.tint(0.12) : Skin.tint(0.06);
                            border-width: 1px;
                            border-color: Skin.tint(0.10);
                            HorizontalLayout {
                                padding-left: Skin.s(12);
                                padding-right: Skin.s(10);
                                Text {
                                    text: root.current-theme == "" ? "default" : root.current-theme;
                                    color: Skin.fg;
                                    font-size: Skin.s(13);
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: "⌄";
                                    color: Skin.fg-dim;
                                    font-size: Skin.s(13);
                                    vertical-alignment: center;
                                }
                            }
                            tb-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    theme-pop.show();
                                }
                            }
                            theme-pop := PopupWindow {
                                x: 0;
                                y: parent.height + Skin.s(4);
                                width: Math.max(theme-btn.width, Skin.s(150));
                                height: Math.min(root.themes.length * Skin.s(34) + Skin.s(8), Skin.s(212));
                                close-policy: PopupClosePolicy.close-on-click-outside;
                                Rectangle {
                                    background: Skin.panel-bg;
                                    border-radius: Skin.s(10);
                                    border-width: 1px;
                                    border-color: Skin.tint(0.14);
                                    ListView {
                                        x: Skin.s(4);
                                        y: Skin.s(4);
                                        width: parent.width - Skin.s(8);
                                        height: parent.height - Skin.s(8);
                                        for th[k] in root.themes: Rectangle {
                                            height: Skin.s(34);
                                            border-radius: Skin.s(7);
                                            background: th-ta.has-hover ? Skin.tint(0.08) : transparent;
                                            HorizontalLayout {
                                                padding-left: Skin.s(10);
                                                padding-right: Skin.s(10);
                                                Text {
                                                    text: th;
                                                    color: th == root.current-theme ? Skin.accent : Skin.fg;
                                                    font-size: Skin.s(13);
                                                    font-weight: th == root.current-theme ? 600 : 400;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                    horizontal-stretch: 1;
                                                }
                                                Text {
                                                    visible: th == root.current-theme;
                                                    text: "✓";
                                                    color: Skin.accent;
                                                    font-size: Skin.s(13);
                                                    vertical-alignment: center;
                                                }
                                            }
                                            th-ta := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.set-setting("theme", th);
                                                    theme-pop.close();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                                save-name := Field {
                                    width: Skin.s(150);
                                    value: "";
                                    placeholder: "my-theme";
                                    edited(v) => { }
                                }
                                PillBtn {
                                    text: "Save as theme";
                                    accent: true;
                                    clicked => {
                                        if (save-name.text-value != "") {
                                            root.save-theme(save-name.text-value);
                                        }
                                    }
                                }
                            }
                            Text {
                                text: "Accent & background apply to themes that don't set their own. \"Save as theme\" snapshots every colour of the current look — theme files hot-reload on edit.";
                                color: Skin.fg-dim;
                                font-size: Skin.s(10);
                                wrap: word-wrap;
                            }
                        }

                        Card {
                            title: "COLOURS";
                            SettingRow {
                                label: "Accent";
                                label-width: Skin.s(84);
                                HorizontalLayout {
                                    spacing: Skin.s(6);
                                    alignment: start;
                                    for phex[k] in root.accent-hexes: Rectangle {
                                        width: Skin.s(22);
                                        height: Skin.s(22);
                                        border-radius: self.width / 2;
                                        background: root.accent-cols[k];
                                        border-width: root.accent-hex.to-lowercase() == phex ? 3px : 0;
                                        border-color: Skin.tint(0.9);
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.set-setting("accent", phex);
                                            }
                                        }
                                    }
                                    PickBtn {
                                        clicked => {
                                            root.open-picker("accent", root.accent-hex);
                                        }
                                    }
                                }
                                Field {
                                    width: Skin.s(90);
                                    value: root.accent-hex;
                                    placeholder: "#rrggbb";
                                    edited(t) => {
                                        if (t.character-count == 7) {
                                            root.set-setting("accent", t.to-lowercase());
                                        }
                                    }
                                }
                            }
                            SettingRow {
                                label: "Background";
                                label-width: Skin.s(84);
                                HorizontalLayout {
                                    spacing: Skin.s(6);
                                    alignment: start;
                                    for phex[k] in root.bg-hexes: Rectangle {
                                        width: Skin.s(22);
                                        height: Skin.s(22);
                                        border-radius: self.width / 2;
                                        background: root.bg-cols[k];
                                        border-width: root.bg-hex.to-lowercase() == phex ? 3px : 1px;
                                        border-color: root.bg-hex.to-lowercase() == phex
                                            ? Skin.tint(0.9)
                                            : Skin.tint(0.2);
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.set-setting("bg", phex);
                                            }
                                        }
                                    }
                                    PickBtn {
                                        clicked => {
                                            root.open-picker("bg", root.bg-hex);
                                        }
                                    }
                                }
                                Field {
                                    width: Skin.s(90);
                                    value: root.bg-hex;
                                    placeholder: "#rrggbb";
                                    edited(t) => {
                                        if (t.character-count == 7) {
                                            root.set-setting("bg", t.to-lowercase());
                                        }
                                    }
                                }
                            }
                            SettingRow {
                                label: "Inactive fill";
                                label-width: Skin.s(84);
                                HorizontalLayout {
                                    spacing: Skin.s(6);
                                    alignment: start;
                                    // "invisible": band shows through (default)
                                    Rectangle {
                                        width: Skin.s(22);
                                        height: Skin.s(22);
                                        border-radius: self.width / 2;
                                        border-width: root.seg-bg-hex == "" ? 3px : 1px;
                                        border-color: root.seg-bg-hex == ""
                                            ? Skin.tint(0.9)
                                            : Skin.tint(0.25);
                                        Rectangle {
                                            width: Skin.s(8);
                                            height: Skin.s(8);
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                            border-radius: self.width / 2;
                                            border-width: 1px;
                                            border-color: Skin.tint(0.5);
                                        }
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.set-setting("segBg", "");
                                            }
                                        }
                                    }
                                    // "=": same as the band colour, gaps cut through
                                    Rectangle {
                                        width: Skin.s(22);
                                        height: Skin.s(22);
                                        border-radius: self.width / 2;
                                        background: Skin.bg;
                                        border-width: root.seg-bg-hex == "bg" ? 3px : 1px;
                                        border-color: root.seg-bg-hex == "bg"
                                            ? Skin.tint(0.9)
                                            : Skin.tint(0.25);
                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: "=";
                                            color: Skin.on-band;
                                            font-size: Skin.s(12);
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.set-setting("segBg", "bg");
                                            }
                                        }
                                    }
                                    for shex[k] in root.seg-hexes: Rectangle {
                                        width: Skin.s(22);
                                        height: Skin.s(22);
                                        border-radius: self.width / 2;
                                        background: root.seg-cols[k];
                                        border-width: root.seg-bg-hex.to-lowercase() == shex ? 3px : 1px;
                                        border-color: root.seg-bg-hex.to-lowercase() == shex
                                            ? Skin.tint(0.9)
                                            : Skin.tint(0.25);
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.set-setting("segBg", shex);
                                            }
                                        }
                                    }
                                    PickBtn {
                                        clicked => {
                                            root.open-picker("segBg", root.seg-bg-hex == "bg" ? "" : root.seg-bg-hex);
                                        }
                                    }
                                }
                                Field {
                                    width: Skin.s(90);
                                    value: root.seg-bg-hex;
                                    placeholder: "#22ffffff";
                                    edited(t) => {
                                        if (t == "" || t == "bg" || t.character-count == 7 || t.character-count == 9) {
                                            root.set-setting("segBg", t);
                                        }
                                    }
                                }
                            }
                        }

                        Card {
                            title: "WHEEL";
                            GridLayout {
                                spacing: Skin.s(8);
                                Row {
                                    CompactSlider {
                                        label: "Icon size";
                                        label-w: Skin.s(84);
                                        minimum: 36;
                                        maximum: 80;
                                        value: root.icon-size;
                                        changed(v) => {
                                            root.set-setting("iconSize", "\{Math.round(v)}");
                                        }
                                    }
                                    CompactSlider {
                                        label: "Ring size";
                                        label-w: Skin.s(88);
                                        minimum: 110;
                                        maximum: 240;
                                        value: root.ring-radius;
                                        changed(v) => {
                                            root.set-setting("ringRadius", "\{Math.round(v)}");
                                        }
                                    }
                                }
                                Row {
                                    CompactSlider {
                                        label: "Hole size";
                                        label-w: Skin.s(84);
                                        minimum: 40;
                                        maximum: 130;
                                        value: root.hole-size;
                                        changed(v) => {
                                            root.set-setting("holeSize", "\{Math.round(v)}");
                                        }
                                    }
                                    CompactSlider {
                                        label: "Backdrop dim";
                                        label-w: Skin.s(88);
                                        suffix: "%";
                                        minimum: 0;
                                        maximum: 0.6;
                                        step: 0.01;
                                        display-mul: 100;
                                        value: root.dim;
                                        changed(v) => {
                                            root.set-setting("dim", "\{Math.round(v * 100) / 100}");
                                        }
                                    }
                                }
                                Row {
                                    CompactSlider {
                                        label: "Wheel opacity";
                                        label-w: Skin.s(84);
                                        suffix: "%";
                                        minimum: 0;
                                        maximum: 1;
                                        step: 0.01;
                                        display-mul: 100;
                                        value: root.wheel-opacity;
                                        changed(v) => {
                                            root.set-setting("wheelOpacity", "\{Math.round(v * 100) / 100}");
                                        }
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: Skin.s(8);
                                alignment: start;
                                ToggleChip {
                                    label: "Labels";
                                    on: root.show-labels;
                                    toggled(v) => {
                                        root.set-setting("showLabels", v ? "true" : "false");
                                    }
                                }
                                ToggleChip {
                                    label: "Window dots";
                                    on: root.show-dots;
                                    toggled(v) => {
                                        root.set-setting("showDots", v ? "true" : "false");
                                    }
                                }
                                ToggleChip {
                                    label: "Follow cursor";
                                    on: root.follow-outside;
                                    toggled(v) => {
                                        root.set-setting("followOutside", v ? "true" : "false");
                                    }
                                }
                            }
                        }

                        Card {
                            title: "SECTIONS";
                            GridLayout {
                                spacing: Skin.s(8);
                                Row {
                                    CompactSlider {
                                        label: "Active radius";
                                        label-w: Skin.s(84);
                                        minimum: 0;
                                        maximum: 28;
                                        step: 0.5;
                                        value: root.sector-radius;
                                        changed(v) => {
                                            root.set-setting("sectorRadius", "\{Math.round(v * 2) / 2}");
                                        }
                                    }
                                    CompactSlider {
                                        label: "Inactive radius";
                                        label-w: Skin.s(88);
                                        minimum: 0;
                                        maximum: 28;
                                        step: 0.5;
                                        value: root.seg-radius;
                                        changed(v) => {
                                            root.set-setting("segRadius", "\{Math.round(v * 2) / 2}");
                                        }
                                    }
                                }
                                Row {
                                    CompactSlider {
                                        label: "Edge padding";
                                        label-w: Skin.s(84);
                                        minimum: 0;
                                        maximum: 20;
                                        step: 0.5;
                                        value: root.section-inset;
                                        changed(v) => {
                                            root.set-setting("sectionInset", "\{Math.round(v * 2) / 2}");
                                        }
                                    }
                                    CompactSlider {
                                        label: "Section gap";
                                        label-w: Skin.s(88);
                                        minimum: 0;
                                        maximum: 24;
                                        step: 0.5;
                                        value: root.seg-gap;
                                        changed(v) => {
                                            root.set-setting("segGap", "\{Math.round(v * 2) / 2}");
                                        }
                                    }
                                }
                            }
                            Text {
                                text: "Give inactive sections a fill (Colours above) plus a gap for a segmented wheel — Wheel opacity 0% keeps only the sections.";
                                color: Skin.fg-dim;
                                font-size: Skin.s(10);
                                wrap: word-wrap;
                            }
                        }


                        Card {
                            title: "RING SHORTCUTS";

                            if !root.can-manage-keybinds: VerticalLayout {
                                spacing: Skin.s(6);
                                Text {
                                    text: "Your compositor has no global-shortcut API RadiAll can drive. Bind these commands in your compositor config instead — they reach the running instance:";
                                    color: Skin.fg-dim;
                                    font-size: Skin.s(12);
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "radiall --apps\nradiall --windows\nradiall --actions";
                                    color: Skin.fg;
                                    font-family: Skin.mono-font;
                                    font-size: Skin.s(12);
                                }
                            }

                            if root.can-manage-keybinds: VerticalLayout {
                                spacing: Skin.s(8);
                                HorizontalLayout {
                                    spacing: Skin.s(8);
                                    alignment: start;
                                    ToggleChip {
                                        label: "Enabled";
                                        on: root.shortcuts-enabled;
                                        toggled(v) => {
                                            root.set-setting("shortcutsEnabled", v ? "true" : "false");
                                        }
                                    }
                                    if root.shortcuts-enabled: ToggleChip {
                                        label: "Bind in Hyprland";
                                        on: root.persist-binds;
                                        toggled(v) => {
                                            root.set-setting("persistBinds", v ? "true" : "false");
                                        }
                                    }
                                }
                                Text {
                                    text: !root.shortcuts-enabled
                                        ? "Off — RadiAll grabs no keys."
                                        : root.persist-binds
                                            ? "Keys are written to ~/.config/hypr/launcher-binds.conf and survive reloads."
                                            : "Keys are applied live via hyprctl — your Hyprland config is left untouched.";
                                    color: Skin.fg-dim;
                                    font-size: Skin.s(10);
                                    wrap: word-wrap;
                                }
                                if root.shortcuts-enabled: HorizontalLayout {
                                    spacing: Skin.s(10);
                                    VerticalLayout {
                                        spacing: Skin.s(4);
                                        Text {
                                            text: "Apps ring";
                                            color: Skin.fg-dim;
                                            font-size: Skin.s(11);
                                        }
                                        ShortcutRecorder {
                                            value: root.sc-apps;
                                            captured(s) => {
                                                root.set-shortcut("apps", s);
                                            }
                                        }
                                    }
                                    VerticalLayout {
                                        spacing: Skin.s(4);
                                        Text {
                                            text: "Windows ring";
                                            color: Skin.fg-dim;
                                            font-size: Skin.s(11);
                                        }
                                        ShortcutRecorder {
                                            value: root.sc-windows;
                                            captured(s) => {
                                                root.set-shortcut("windows", s);
                                            }
                                        }
                                    }
                                    VerticalLayout {
                                        spacing: Skin.s(4);
                                        Text {
                                            text: "Actions ring";
                                            color: Skin.fg-dim;
                                            font-size: Skin.s(11);
                                        }
                                        ShortcutRecorder {
                                            value: root.sc-actions;
                                            captured(s) => {
                                                root.set-shortcut("actions", s);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ------------------------------------------------------- footer
            HorizontalLayout {
                spacing: Skin.s(8);
                PillBtn {
                    text: "Reset settings";
                    clicked => {
                        root.reset-settings();
                    }
                }
                Rectangle { } // spacer
                PillBtn {
                    text: "Done";
                    accent: true;
                    min-width: Skin.s(66);
                    clicked => {
                        root.close-requested();
                    }
                }
            }
        }
    }

    // ------------------------------------------- installed-app picker overlay
    if root.picking: Rectangle {
        border-radius: Skin.s(20);
        // fully opaque: translucent panel-bg lets the list below ghost through
        background: Skin.panel-bg.with-alpha(1.0);
        border-width: 1px;
        border-color: Skin.tint(0.10);

        TouchArea { } // swallow clicks under the overlay

        VerticalLayout {
            padding: Skin.s(16);
            spacing: Skin.s(10);

            HorizontalLayout {
                spacing: Skin.s(8);
                IconBtn {
                    glyph: "‹";
                    clicked => {
                        root.picking = false;
                    }
                }
                Text {
                    text: "Add an app";
                    font-family: Skin.font-display;
                    font-size: Skin.s(17);
                    font-weight: 600;
                    color: Skin.fg-strong;
                    vertical-alignment: center;
                }
            }

            Field {
                value: "";
                placeholder: "Search installed apps…";
                edited(t) => {
                    root.pick-query(t);
                }
            }

            ListView {
                vertical-stretch: 1;
                for entry in root.installed: Rectangle {
                    height: Skin.s(40);
                    border-radius: Skin.s(8);
                    background: inst-ta.has-hover ? Skin.tint(0.10) : transparent;
                    HorizontalLayout {
                        padding-left: Skin.s(10);
                        padding-right: Skin.s(12);
                        spacing: Skin.s(10);
                        Rectangle {
                            width: Skin.s(26);
                            if entry.has-icon: Image {
                                width: Skin.s(26);
                                height: Skin.s(26);
                                y: (parent.height - self.height) / 2;
                                source: entry.icon;
                                image-fit: contain;
                            }
                        }
                        Text {
                            text: entry.name;
                            color: Skin.fg;
                            font-size: Skin.s(13);
                            vertical-alignment: center;
                            overflow: elide;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: "+";
                            color: Skin.fg-dim;
                            font-size: Skin.s(14);
                            vertical-alignment: center;
                        }
                    }
                    inst-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.add-installed(entry.idx);
                            root.picking = false;
                        }
                    }
                }
            }
        }
    }

    // ------------------------------------------- action icon picker overlay
    if root.picking-icon-for != "": Rectangle {
        border-radius: Skin.s(20);
        background: Skin.panel-bg.with-alpha(1.0);
        border-width: 1px;
        border-color: Skin.tint(0.10);

        TouchArea { } // swallow clicks under the overlay

        VerticalLayout {
            padding: Skin.s(16);
            spacing: Skin.s(10);

            HorizontalLayout {
                spacing: Skin.s(8);
                IconBtn {
                    glyph: "‹";
                    clicked => {
                        root.picking-icon-for = "";
                    }
                }
                Text {
                    text: "Pick an icon";
                    font-family: Skin.font-display;
                    font-size: Skin.s(17);
                    font-weight: 600;
                    color: Skin.fg-strong;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.icon-lib-count + " icons";
                    color: Skin.fg-dim;
                    font-size: Skin.s(12);
                    vertical-alignment: center;
                }
            }

            Field {
                value: "";
                placeholder: "Search icons (reload, terminal, play, …)";
                edited(t) => {
                    root.icon-query(t);
                }
            }

            if root.icon-lib-count == 0: Text {
                text: "No icon library found. Drop SVG sets into ~/.config/radiall/icons/<set>/*.svg — the icon collection of a previous Quickshell-based install (~/.config/quickshell/icons) is picked up automatically.";
                color: Skin.fg-dim;
                font-size: Skin.s(12);
                wrap: word-wrap;
            }

            ListView {
                vertical-stretch: 1;
                for entry in root.icon-picks: Rectangle {
                    height: Skin.s(36);
                    border-radius: Skin.s(8);
                    background: ic-ta.has-hover ? Skin.tint(0.10) : transparent;
                    HorizontalLayout {
                        padding-left: Skin.s(10);
                        padding-right: Skin.s(12);
                        spacing: Skin.s(10);
                        Rectangle {
                            width: Skin.s(22);
                            Image {
                                width: Skin.s(22);
                                height: Skin.s(22);
                                y: (parent.height - self.height) / 2;
                                source: entry.icon;
                                // glyph sets are monochrome -> tint to fg;
                                // real app icons keep their own colors
                                colorize: entry.set == "apps" ? transparent : Skin.fg;
                                image-fit: contain;
                            }
                        }
                        Text {
                            text: entry.name;
                            color: Skin.fg;
                            font-size: Skin.s(13);
                            vertical-alignment: center;
                            overflow: elide;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: entry.set;
                            color: Skin.fg-dim;
                            font-size: Skin.s(11);
                            vertical-alignment: center;
                        }
                    }
                    ic-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.icon-picked(root.picking-icon-for, entry.path);
                            root.picking-icon-for = "";
                        }
                    }
                }
            }
        }
    }

    // ---------------------------------------------------- color picker popover
    // HSV picker editing root.picker-h/s/v/a (seeded by Rust via open-picker);
    // every change emits color-picked(target, h, s, v, a) -> applied LIVE.
    if root.picker-for != "": Rectangle {
        // scrim: click-away closes
        background: #00000059;
        TouchArea {
            clicked => {
                root.picker-for = "";
            }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: Skin.s(320);
            height: pick-col.preferred-height + Skin.s(32);
            border-radius: Skin.s(16);
            background: Skin.panel-bg.with-alpha(1.0);
            border-width: 1px;
            border-color: Skin.tint(0.14);
            TouchArea { } // swallow clicks

            pick-col := VerticalLayout {
                x: Skin.s(16);
                y: Skin.s(16);
                width: parent.width - Skin.s(32);
                spacing: Skin.s(10);

                // saturation (x) / value (y) square over the pure hue
                sv := Rectangle {
                    height: Skin.s(160);
                    border-radius: Skin.s(8);
                    clip: true;
                    background: Colors.hsv(root.picker-h, 1, 1);
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        background: @linear-gradient(90deg, #ffffffff 0%, #ffffff00 100%);
                    }
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        background: @linear-gradient(180deg, #00000000 0%, #000000ff 100%);
                    }
                    // marker
                    Rectangle {
                        x: root.picker-s * parent.width - self.width / 2;
                        y: (1 - root.picker-v) * parent.height - self.height / 2;
                        width: Skin.s(14);
                        height: Skin.s(14);
                        border-radius: self.width / 2;
                        border-width: 2px;
                        border-color: white;
                        drop-shadow-color: #00000080;
                        drop-shadow-blur: 3px;
                    }
                    sv-ta := TouchArea {
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down || e.kind == PointerEventKind.move) {
                                if (self.pressed || e.kind == PointerEventKind.down) {
                                    root.picker-s = Math.clamp(self.mouse-x / parent.width, 0, 1);
                                    root.picker-v = Math.clamp(1 - self.mouse-y / parent.height, 0, 1);
                                    root.color-picked(root.picker-for, root.picker-h, root.picker-s, root.picker-v, root.picker-a);
                                }
                            }
                        }
                    }
                }

                // hue bar
                hue-bar := Rectangle {
                    height: Skin.s(16);
                    border-radius: Skin.s(8);
                    background: @linear-gradient(90deg,
                        #ff0000 0%, #ffff00 16.7%, #00ff00 33.3%, #00ffff 50%,
                        #0000ff 66.7%, #ff00ff 83.3%, #ff0000 100%);
                    Rectangle {
                        x: root.picker-h / 360 * (parent.width - self.width);
                        width: Skin.s(10);
                        height: 100%;
                        border-radius: Skin.s(5);
                        border-width: 2px;
                        border-color: white;
                        background: Colors.hsv(root.picker-h, 1, 1);
                    }
                    TouchArea {
                        pointer-event(e) => {
                            if (self.pressed || e.kind == PointerEventKind.down) {
                                root.picker-h = Math.clamp(self.mouse-x / parent.width, 0, 1) * 360;
                                root.color-picked(root.picker-for, root.picker-h, root.picker-s, root.picker-v, root.picker-a);
                            }
                        }
                    }
                }

                // alpha bar
                alpha-bar := Rectangle {
                    height: Skin.s(16);
                    border-radius: Skin.s(8);
                    background: Skin.tint(0.08);
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: parent.border-radius;
                        background: @linear-gradient(90deg,
                            Colors.hsv(root.picker-h, root.picker-s, root.picker-v).with-alpha(0.0) 0%,
                            Colors.hsv(root.picker-h, root.picker-s, root.picker-v) 100%);
                    }
                    Rectangle {
                        x: root.picker-a * (parent.width - self.width);
                        width: Skin.s(10);
                        height: 100%;
                        border-radius: Skin.s(5);
                        border-width: 2px;
                        border-color: white;
                    }
                    TouchArea {
                        pointer-event(e) => {
                            if (self.pressed || e.kind == PointerEventKind.down) {
                                root.picker-a = Math.clamp(self.mouse-x / parent.width, 0, 1);
                                root.color-picked(root.picker-for, root.picker-h, root.picker-s, root.picker-v, root.picker-a);
                            }
                        }
                    }
                }

                // preview + done
                HorizontalLayout {
                    spacing: Skin.s(10);
                    Rectangle {
                        width: Skin.s(32);
                        height: Skin.s(32);
                        border-radius: self.width / 2;
                        background: Colors.hsv(root.picker-h, root.picker-s, root.picker-v).with-alpha(root.picker-a);
                        border-width: 1px;
                        border-color: Skin.tint(0.3);
                    }
                    Text {
                        text: "Changes apply live.";
                        color: Skin.fg-dim;
                        font-size: Skin.s(12);
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    PillBtn {
                        text: "Done";
                        accent: true;
                        clicked => {
                            root.picker-for = "";
                        }
                    }
                }
            }
        }
    }
}
