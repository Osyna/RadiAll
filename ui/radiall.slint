// RadiAll root windows.
//   RingWindow    — transparent frameless screen-covering overlay: dim layer,
//                   the wheel, the per-app action arc, and ONE fullscreen
//                   input surface whose raw events all route to Rust (the
//                   whole interaction state machine lives in src/ui.rs).
//   SettingsWindow — normal window: live preview wheel + the editor.

import { Skin } from "skin.slint";
import { RingItem, ArcItem, AppRow, ActionRow, InstalledRow, IconPick } from "types.slint";
import { Wheel, ActionArc } from "wheel.slint";
import { Editor } from "editor.slint";

export { Skin }

export component RingWindow inherits Window {
    no-frame: true;
    always-on-top: true;
    background: transparent;
    title: "RadiAll";
    default-font-family: Skin.font;
    preferred-width: 1280px;
    preferred-height: 800px;

    in property <bool> open: false;            // drives open/close animations
    in property <float> dim: 0.28;

    // wheel model + geometry (see Wheel for docs)
    in property <length> outer-r;
    in property <length> inner-r;
    in property <length> ring-r;
    in property <length> icon-box;
    // layout engine (0 radial / 1 bar / 2 half) + position (0 center,
    // 1 left, 2 right, 3 top, 4 bottom); placement mirrors Geometry::menu_origin
    in property <int> menu-layout: 0;
    in property <int> menu-pos: 0;
    in property <float> a0-deg: 180;
    in property <length> bar-pitch;
    in property <length> bar-thick;
    in property <length> bar-pad;
    in property <[RingItem]> items;
    in property <int> hovered-index: -1;
    in property <int> active-index: 0;
    in property <float> sector-rotation;
    in property <color> wedge-color: Skin.sector;
    in property <string> center-label;
    in property <bool> show-settings-btn;
    in property <image> logo;
    in property <image> focus-icon;
    in property <bool> show-focus-icon;
    in property <bool> actions-mode;
    // arc anchor (window coords; radial = window center, bar/half = the
    // hovered item, pushed by Rust when the arc opens)
    in property <length> arc-cx;
    in property <length> arc-cy;

    // action arc
    in property <bool> arc-open: false;
    in property <[ArcItem]> arc-items;
    in property <string> arc-label;
    in property <length> arc-radius;
    in property <length> arc-btn-r;
    in property <length> arc-band-inner;
    in property <length> arc-band-outer;
    in property <int> arc-mode;             // 0 radial, 1 bar, 2 half
    in property <string> arc-band-path;     // ring band SVG (viewbox 0..2*band-outer)
    in property <length> arc-bar-cx;        // bar strip centre / dims (arc-local)
    in property <length> arc-bar-cy;
    in property <length> arc-bar-w;
    in property <length> arc-bar-h;
    in property <length> arc-label-x;       // label pill centre (arc-local)
    in property <length> arc-label-y;

    // raw input -> Rust state machine (coords are window-local px)
    callback pointer-moved(length, length);
    callback pointer-down(length, length, bool /* right button */);
    callback pointer-up(length, length, bool);
    callback scrolled(length, length, float /* delta-y, +down */);
    callback esc-pressed();
    callback arc-clicked(int);

    // full-screen dim
    Rectangle {
        width: 100%;
        height: 100%;
        background: Skin.backdrop;
        opacity: root.open ? root.dim : 0;
        animate opacity { duration: 160ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }
    }

    wheel-wrap := Rectangle {
        private property <bool> is-bar: root.menu-layout == 1;
        private property <bool> is-half: root.menu-layout == 2;
        private property <bool> bar-v: self.is-bar && (root.menu-pos == 1 || root.menu-pos == 2);
        private property <length> bar-len: root.items.length * root.bar-pitch + 2 * root.bar-pad;
        private property <length> edge-m: root.bar-pad * 1.5;
        width: self.is-bar ? (self.bar-v ? root.bar-thick : self.bar-len) : 2 * root.outer-r;
        height: self.is-bar ? (self.bar-v ? self.bar-len : root.bar-thick) : 2 * root.outer-r;
        // mirrors Geometry::menu_origin — half rings center ON the edge
        x: self.is-half
            ? (root.menu-pos == 1 ? -root.outer-r
                : root.menu-pos == 2 ? parent.width - root.outer-r
                : (parent.width - self.width) / 2)
            : self.is-bar
                ? (root.menu-pos == 1 ? self.edge-m
                    : root.menu-pos == 2 ? parent.width - self.edge-m - self.width
                    : (parent.width - self.width) / 2)
                : (parent.width - self.width) / 2;
        y: self.is-half
            ? (root.menu-pos == 3 ? -root.outer-r
                : root.menu-pos == 1 || root.menu-pos == 2 ? (parent.height - self.height) / 2
                : parent.height - root.outer-r)
            : self.is-bar
                ? (root.menu-pos == 3 ? self.edge-m
                    : root.menu-pos == 4 ? parent.height - self.edge-m - self.height
                    : (parent.height - self.height) / 2)
                : (parent.height - self.height) / 2;
        opacity: root.open ? 1 : 0;
        animate opacity { duration: 170ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }

        Wheel {
            width: 100%;
            height: 100%;
            // pop 0.9 -> 1 stands in for QML's scale open animation
            pop: root.open ? 1.0 : 0.9;
            animate pop { duration: 200ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
            outer-r: root.outer-r;
            inner-r: root.inner-r;
            ring-r: root.ring-r;
            icon-box: root.icon-box;
            layout: root.menu-layout;
            a0-deg: root.a0-deg;
            bar-vertical: wheel-wrap.bar-v;
            bar-pitch: root.bar-pitch;
            bar-thick: root.bar-thick;
            bar-pad: root.bar-pad;
            // pill hangs away from the anchored edge (top bar -> below, left
            // bar -> right of it); center/bottom default above
            pill-side: root.menu-pos == 3 || root.menu-pos == 1 ? 1 : -1;
            items: root.items;
            hovered-index: root.hovered-index;
            active-index: root.active-index;
            sector-rotation: root.sector-rotation;
            wedge-color: root.wedge-color;
            center-label: root.center-label;
            show-settings-btn: root.show-settings-btn;
            logo: root.logo;
            focus-icon: root.focus-icon;
            show-focus-icon: root.show-focus-icon;
            actions-mode: root.actions-mode;
        }
    }

    // ONE input surface for everything except the arc buttons (stacked above).
    ta := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: pointer;
        // NOTE: TouchArea.moved only fires while pressed; hover tracking
        // must use pointer-event's move kind.
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move) {
                root.pointer-moved(self.mouse-x, self.mouse-y);
            } else if (e.kind == PointerEventKind.down) {
                root.pointer-down(self.mouse-x, self.mouse-y, e.button == PointerEventButton.right);
            } else if (e.kind == PointerEventKind.up) {
                root.pointer-up(self.mouse-x, self.mouse-y, e.button == PointerEventButton.right);
            }
        }
        scroll-event(e) => {
            root.scrolled(self.mouse-x, self.mouse-y, -e.delta-y / 1px);
            accept
        }
    }

    ActionArc {
        x: root.arc-cx - self.width / 2;
        y: root.arc-cy - self.height / 2;
        open: root.arc-open;
        items: root.arc-items;
        app-label: root.arc-label;
        arc-radius: root.arc-radius;
        btn-r: root.arc-btn-r;
        band-inner: root.arc-band-inner;
        band-outer: root.arc-band-outer;
        mode: root.arc-mode;
        band-path: root.arc-band-path;
        bar-cx: root.arc-bar-cx;
        bar-cy: root.arc-bar-cy;
        bar-w: root.arc-bar-w;
        bar-h: root.arc-bar-h;
        label-x: root.arc-label-x;
        label-y: root.arc-label-y;
        action-clicked(i) => {
            root.arc-clicked(i);
        }
    }

    forward-focus: keys;
    keys := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.esc-pressed();
                return accept;
            }
            reject
        }
    }
}

export component SettingsWindow inherits Window {
    title: "RadiAll Settings";
    default-font-family: Skin.font;
    background: Skin.panel-bg;
    // Fixed size = non-resizable (min == max for the compositor); floats
    // centered via the Hyprland rules the daemon applies at startup.
    width: 1140px;
    height: 720px;

    // ---- preview wheel (small, non-interactive) ----
    in property <length> pv-outer-r;
    in property <length> pv-inner-r;
    in property <length> pv-ring-r;
    in property <length> pv-icon-box;
    in property <int> pv-layout: 0;
    in property <int> pv-pos: 0;
    in property <float> pv-a0-deg: 180;
    in property <length> pv-bar-pitch;
    in property <length> pv-bar-thick;
    in property <length> pv-bar-pad;
    in property <float> pv-scale: 0.5;   // preview wheel ui-scale
    in property <[RingItem]> pv-items;
    in property <int> pv-active-index: 0;
    in property <string> pv-label;

    // ---- editor surface, forwarded 1:1 (see Editor for docs) ----
    in property <[AppRow]> apps <=> ed.apps;
    in property <int> selected-app <=> ed.selected-app;
    in property <[ActionRow]> app-actions <=> ed.app-actions;
    in property <[ActionRow]> default-actions <=> ed.default-actions;
    in property <[InstalledRow]> installed <=> ed.installed;
    in property <[IconPick]> icon-picks <=> ed.icon-picks;
    in property <int> icon-lib-count <=> ed.icon-lib-count;
    in property <[string]> themes <=> ed.themes;
    in property <string> current-theme <=> ed.current-theme;
    in property <string> accent-hex <=> ed.accent-hex;
    in property <string> bg-hex <=> ed.bg-hex;
    in property <float> icon-size <=> ed.icon-size;
    in property <float> ring-radius <=> ed.ring-radius;
    in property <float> dim <=> ed.dim;
    in property <float> wheel-opacity <=> ed.wheel-opacity;
    in property <bool> show-labels <=> ed.show-labels;
    in property <bool> follow-outside <=> ed.follow-outside;
    in property <float> hole-size <=> ed.hole-size;
    in property <bool> show-dots <=> ed.show-dots;
    in property <string> menu-layout-name <=> ed.menu-layout-name;
    in property <string> menu-pos-name <=> ed.menu-pos-name;
    in property <float> sector-radius <=> ed.sector-radius;
    in property <float> seg-radius <=> ed.seg-radius;
    in property <float> section-inset <=> ed.section-inset;
    in property <float> seg-gap <=> ed.seg-gap;
    in property <string> seg-bg-hex <=> ed.seg-bg-hex;
    in property <string> border-hex <=> ed.border-hex;
    in property <float> border-width <=> ed.border-width;
    in property <bool> shortcuts-enabled <=> ed.shortcuts-enabled;
    in property <bool> persist-binds <=> ed.persist-binds;
    in property <string> sc-apps <=> ed.sc-apps;
    in property <string> sc-windows <=> ed.sc-windows;
    in property <string> sc-actions <=> ed.sc-actions;
    in property <string> keybind-backend <=> ed.keybind-backend;
    in property <bool> can-send-keys <=> ed.can-send-keys;
    in property <string> window-backend <=> ed.window-backend;

    callback select-app <=> ed.select-app;
    callback add-app <=> ed.add-app;
    callback add-installed <=> ed.add-installed;
    callback remove-app <=> ed.remove-app;
    callback move-app <=> ed.move-app;
    callback reorder-app <=> ed.reorder-app;
    callback set-app-field <=> ed.set-app-field;
    callback toggle-action <=> ed.toggle-action;
    callback add-custom-action <=> ed.add-custom-action;
    callback remove-custom-action <=> ed.remove-custom-action;
    callback set-custom-field <=> ed.set-custom-field;
    callback set-setting <=> ed.set-setting;
    callback set-shortcut <=> ed.set-shortcut;
    callback reset-settings <=> ed.reset-settings;
    callback save-theme <=> ed.save-theme;
    callback close-requested <=> ed.close-requested;
    callback pick-query <=> ed.pick-query;
    callback icon-query <=> ed.icon-query;
    callback open-picker <=> ed.open-picker;
    callback color-picked <=> ed.color-picked;
    callback icon-picked <=> ed.icon-picked;
    in-out property <string> picker-for <=> ed.picker-for;
    in-out property <float> picker-h <=> ed.picker-h;
    in-out property <float> picker-s <=> ed.picker-s;
    in-out property <float> picker-v <=> ed.picker-v;
    in-out property <float> picker-a <=> ed.picker-a;

    HorizontalLayout {
        padding: 18px;
        spacing: 18px;

        // live preview pane — a mini screen: the menu positions itself with
        // the same rules as the real overlay (half rings clip on the edge)
        Rectangle {
            width: 380px;
            border-radius: 20px;
            background: Skin.panel-bg.darker(20%);
            border-width: 1px;
            border-color: Skin.tint(0.10);
            clip: true;
            private property <bool> is-bar: root.pv-layout == 1;
            private property <bool> is-half: root.pv-layout == 2;
            private property <bool> bar-v: self.is-bar && (root.pv-pos == 1 || root.pv-pos == 2);
            private property <length> edge-m: root.pv-bar-pad * 1.5;
            Wheel {
                x: parent.is-half
                    ? (root.pv-pos == 1 ? -root.pv-outer-r
                        : root.pv-pos == 2 ? parent.width - root.pv-outer-r
                        : (parent.width - self.width) / 2)
                    : parent.is-bar
                        ? (root.pv-pos == 1 ? parent.edge-m
                            : root.pv-pos == 2 ? parent.width - parent.edge-m - self.width
                            : (parent.width - self.width) / 2)
                        : (parent.width - self.width) / 2;
                y: parent.is-half
                    ? (root.pv-pos == 3 ? -root.pv-outer-r
                        : root.pv-pos == 1 || root.pv-pos == 2 ? (parent.height - self.height) / 2
                        : parent.height - root.pv-outer-r)
                    : parent.is-bar
                        ? (root.pv-pos == 3 ? parent.edge-m
                            : root.pv-pos == 4 ? parent.height - parent.edge-m - self.height
                            : (parent.height - self.height) / 2)
                        : (parent.height - self.height) / 2;
                outer-r: root.pv-outer-r;
                inner-r: root.pv-inner-r;
                ring-r: root.pv-ring-r;
                icon-box: root.pv-icon-box;
                layout: root.pv-layout;
                a0-deg: root.pv-a0-deg;
                bar-vertical: parent.bar-v;
                bar-pitch: root.pv-bar-pitch;
                bar-thick: root.pv-bar-thick;
                bar-pad: root.pv-bar-pad;
                pill-side: root.pv-pos == 3 || root.pv-pos == 1 ? 1 : -1;
                gscale: root.pv-scale;
                items: root.pv-items;
                hovered-index: root.pv-active-index;
                active-index: root.pv-active-index;
                sector-rotation: 0;
                center-label: root.pv-label;
                show-settings-btn: false;
                actions-mode: false;
                show-focus-icon: false;
            }
        }

        ed := Editor { }
    }
}

// System tray (StatusNotifierItem via ksni on Linux, native elsewhere).
// Replaces the old python tray.py helper.
export component Tray inherits SystemTrayIcon {
    icon: @image-url("../launcher/RadiAll.png");
    tooltip: "RadiAll";

    // "apps" | "windows" | "actions" | "settings" | "quit"
    callback command(string);

    Menu {
        MenuItem {
            title: "Apps ring";
            activated => { root.command("apps"); }
        }
        MenuItem {
            title: "Windows ring";
            activated => { root.command("windows"); }
        }
        MenuItem {
            title: "Focus actions";
            activated => { root.command("actions"); }
        }
        MenuSeparator { }
        MenuItem {
            title: "Settings…";
            activated => { root.command("settings"); }
        }
        MenuSeparator { }
        MenuItem {
            title: "Quit RadiAll";
            activated => { root.command("quit"); }
        }
    }
}
