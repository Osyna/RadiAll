// The radial wheel + per-app action arc. Pure rendering: every piece of
// interaction state (hover, rotation, labels, arc contents) is computed in
// Rust and pushed through the properties below.
//
// Screen coords: +y down, angle 0deg = +x (right), -90deg = straight up;
// ring indices increase clockwise from the top. All drawn geometry is
// multiplied by `pop` (open animation, scales about the wheel center).

import { Skin } from "skin.slint";
import { RingItem, ArcItem } from "types.slint";

export component Wheel {
    // ---- geometry, px, pre-scaled by Rust (Skin.scale and ui-scale applied) ----
    // Every drawn coordinate must ALSO multiply by `pop` (open-animation scale).
    in property <float> pop: 1.0;
    in property <length> outer-r;
    in property <length> inner-r;
    in property <length> ring-r;
    in property <length> icon-box;
    // ---- model ----
    in property <[RingItem]> items;
    in property <int> hovered-index: -1;      // -1 = none (accent wedge fades out)
    in property <int> active-index: 0;        // latched last hover (wedge stays put)
    in property <float> sector-rotation;      // deg accumulator (shortest-path, Rust)

    // ---- center hole content ----
    in property <string> center-label;        // "" hides the pill
    in property <bool> show-settings-btn;
    in property <image> logo;                 // the radish
    in property <image> focus-icon;           // actions-mode app icon
    in property <bool> show-focus-icon;
    in property <bool> actions-mode;

    // settings-button click is resolved in Rust via hit-testing; no input here.

    width: 2 * root.outer-r;
    height: 2 * root.outer-r;

    // ---- derived (all divisions guarded against items = []) ----
    private property <int> count: root.items.length;
    private property <angle> seg-ang: 360deg / Math.max(root.count, 1);
    private property <float> cxf: root.outer-r / 1px;                 // center, px
    private property <float> for-: root.outer-r / 1px * root.pop;     // outer radius, popped
    private property <float> fir: root.inner-r / 1px * root.pop;      // inner radius, popped

    // ---- parametric sections ----
    // Rounded annular sectors via the fill + thick round-joined stroke
    // technique: path inset by (inset + radius), stroke width 2*radius
    // expands back to the inset edge with corner radius = radius.
    // Skin geometry values are design-scaled px; gscale (settings preview)
    // and pop (open animation) apply here.
    in property <float> gscale: 1.0;
    private property <float> gk: root.gscale * root.pop;
    private property <bool> cell-edge: Skin.edge.alpha > 0;
    // cell-shading keeps its bold sharp-corner look: radius forced 0
    private property <float> srad: root.cell-edge ? 0.0 : Skin.sector-radius * root.gk;
    private property <float> irad: root.cell-edge ? 0.0 : Skin.seg-radius * root.gk;
    private property <float> sinset: root.cell-edge
        ? (Skin.s(Skin.edge-width) / 1px) / 2 * root.pop
        : Skin.section-inset * root.gk;
    private property <float> hgap: Skin.seg-gap * root.gk / 2.0;

    // wedge fill: Rust resolves theme override / per-app color / auto mix
    in property <color> wedge-color: Skin.sector;
    private property <color> sector-c: root.wedge-color;
    animate sector-c { duration: 120ms; }

    // wedge rotation: fixed top wedge rotated by the Rust-side shortest-path
    // accumulator; animated here (Path has no rotation-angle in Slint 1.17,
    // so the rotation is baked into the arc coordinates).
    private property <float> rot: root.sector-rotation;
    animate rot { duration: 160ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }
    private property <angle> wspan: root.count <= 1 ? 359.9deg : root.seg-ang;

    // wedge path radii + per-edge angular insets (gap/2 + corner radius,
    // converted to degrees at that edge's radius)
    private property <float> sro: Math.max(root.for- - root.sinset - root.srad, 1.0);
    private property <float> sri: Math.clamp(root.fir + root.sinset + root.srad, 1.0, root.sro - 0.5);
    private property <angle> wgo: Math.min((root.hgap + root.srad) / root.sro * 57.29578deg, root.wspan / 2 - 0.05deg);
    private property <angle> wgi: Math.min((root.hgap + root.srad) / root.sri * 57.29578deg, root.wspan / 2 - 0.05deg);
    private property <angle> wa0o: -90deg - root.wspan / 2 + root.rot * 1deg + root.wgo;
    private property <angle> wa1o: -90deg + root.wspan / 2 + root.rot * 1deg - root.wgo;
    private property <angle> wa0i: -90deg - root.wspan / 2 + root.rot * 1deg + root.wgi;
    private property <angle> wa1i: -90deg + root.wspan / 2 + root.rot * 1deg - root.wgi;

    // inactive segments share the math (their own radius, no rotation)
    private property <float> gro: Math.max(root.for- - root.sinset - root.irad, 1.0);
    private property <float> gri: Math.clamp(root.fir + root.sinset + root.irad, 1.0, root.gro - 0.5);
    private property <angle> ggo: Math.min((root.hgap + root.irad) / root.gro * 57.29578deg, root.wspan / 2 - 0.05deg);
    private property <angle> ggi: Math.min((root.hgap + root.irad) / root.gri * 57.29578deg, root.wspan / 2 - 0.05deg);

    // rim circles sit half a line-width inside/outside the band edges
    private property <float> rimw: Skin.rim-width * root.pop;
    private property <float> rro: root.for- - root.rimw / 2;
    private property <float> rri: root.fir + root.rimw / 2;

    private property <bool> pill-on: Skin.show-labels
        && root.center-label != "" && !root.show-settings-btn;

    // ---- 1. donut band (even-odd punches the hole) ----
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: self.width / 1px;
        viewbox-height: self.height / 1px;
        fill: Skin.bg.with-alpha(Skin.wheel-opacity);
        fill-rule: evenodd;
        MoveTo { x: root.cxf - root.for-; y: root.cxf; }
        ArcTo { x: root.cxf + root.for-; y: root.cxf; radius-x: root.for-; radius-y: root.for-; sweep: true; }
        ArcTo { x: root.cxf - root.for-; y: root.cxf; radius-x: root.for-; radius-y: root.for-; sweep: true; }
        Close { }
        MoveTo { x: root.cxf - root.fir; y: root.cxf; }
        ArcTo { x: root.cxf + root.fir; y: root.cxf; radius-x: root.fir; radius-y: root.fir; sweep: true; }
        ArcTo { x: root.cxf - root.fir; y: root.cxf; radius-x: root.fir; radius-y: root.fir; sweep: true; }
        Close { }
    }

    // ---- 1b. inactive sections (only when the theme/settings give them a
    //      fill; same rounded-sector technique as the wedge) ----
    if Skin.seg-bg.alpha > 0: Rectangle {
        width: 100%;
        height: 100%;
        for it[i] in root.items: sp := Path {
            private property <angle> ca: -90deg + i * root.seg-ang;
            width: 100%;
            height: 100%;
            viewbox-width: self.width / 1px;
            viewbox-height: self.height / 1px;
            fill: Skin.seg-bg;
            stroke: Skin.seg-bg;
            stroke-width: 2 * root.irad * 1px;
            stroke-line-cap: round;
            stroke-line-join: round;
            MoveTo {
                x: root.cxf + root.gro * Math.cos(sp.ca - root.wspan / 2 + root.ggo);
                y: root.cxf + root.gro * Math.sin(sp.ca - root.wspan / 2 + root.ggo);
            }
            ArcTo {
                x: root.cxf + root.gro * Math.cos(sp.ca + root.wspan / 2 - root.ggo);
                y: root.cxf + root.gro * Math.sin(sp.ca + root.wspan / 2 - root.ggo);
                radius-x: root.gro;
                radius-y: root.gro;
                sweep: true;
                large-arc: root.wspan - 2 * root.ggo > 180deg;
            }
            LineTo {
                x: root.cxf + root.gri * Math.cos(sp.ca + root.wspan / 2 - root.ggi);
                y: root.cxf + root.gri * Math.sin(sp.ca + root.wspan / 2 - root.ggi);
            }
            ArcTo {
                x: root.cxf + root.gri * Math.cos(sp.ca - root.wspan / 2 + root.ggi);
                y: root.cxf + root.gri * Math.sin(sp.ca - root.wspan / 2 + root.ggi);
                radius-x: root.gri;
                radius-y: root.gri;
                sweep: false;
                large-arc: root.wspan - 2 * root.ggi > 180deg;
            }
            Close { }
        }
    }

    // ---- 2. accent sector wedge (rounded annular sector) ----
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: self.width / 1px;
        viewbox-height: self.height / 1px;
        fill: root.sector-c;
        stroke: root.sector-c;
        stroke-width: (root.cell-edge ? 1.0 * root.pop : 2 * root.srad) * 1px;
        stroke-line-cap: round;
        stroke-line-join: round;
        opacity: root.hovered-index >= 0 && root.count > 0 ? 1 : 0;
        animate opacity { duration: 110ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }
        MoveTo { x: root.cxf + root.sro * Math.cos(root.wa0o); y: root.cxf + root.sro * Math.sin(root.wa0o); }
        ArcTo {
            x: root.cxf + root.sro * Math.cos(root.wa1o);
            y: root.cxf + root.sro * Math.sin(root.wa1o);
            radius-x: root.sro;
            radius-y: root.sro;
            sweep: true;
            large-arc: root.wa1o - root.wa0o > 180deg;
        }
        LineTo { x: root.cxf + root.sri * Math.cos(root.wa1i); y: root.cxf + root.sri * Math.sin(root.wa1i); }
        ArcTo {
            x: root.cxf + root.sri * Math.cos(root.wa0i);
            y: root.cxf + root.sri * Math.sin(root.wa0i);
            radius-x: root.sri;
            radius-y: root.sri;
            sweep: false;
            large-arc: root.wa1i - root.wa0i > 180deg;
        }
        Close { }
    }

    // ---- 3. rim (drawn on top of the sector so the outline is seamless) ----
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: self.width / 1px;
        viewbox-height: self.height / 1px;
        fill: transparent;
        stroke: Skin.rim;                      // color + alpha precomputed in Rust
        stroke-width: root.rimw * 1px;
        MoveTo { x: root.cxf - root.rro; y: root.cxf; }
        ArcTo { x: root.cxf + root.rro; y: root.cxf; radius-x: root.rro; radius-y: root.rro; sweep: true; }
        ArcTo { x: root.cxf - root.rro; y: root.cxf; radius-x: root.rro; radius-y: root.rro; sweep: true; }
        Close { }
        MoveTo { x: root.cxf - root.rri; y: root.cxf; }
        ArcTo { x: root.cxf + root.rri; y: root.cxf; radius-x: root.rri; radius-y: root.rri; sweep: true; }
        ArcTo { x: root.cxf - root.rri; y: root.cxf; radius-x: root.rri; radius-y: root.rri; sweep: true; }
        Close { }
    }

    // ---- 4. actions-mode focused-app icon (lives in the hole) ----
    if root.show-focus-icon: Image {
        source: root.focus-icon;
        width: root.inner-r * 0.74 * root.pop;
        height: self.width;
        x: root.outer-r - self.width / 2;
        y: root.outer-r - root.inner-r * 0.24 * root.pop - self.height / 2;
    }

    // ---- 5. settings button (QML z0: under icons/pill, spatially separate) ----
    Rectangle {
        private property <float> ss: root.show-settings-btn ? 1.0 : 0.6;
        animate ss { duration: 180ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
        private property <length> dia: Skin.s(82) * self.ss * root.pop;
        opacity: root.show-settings-btn ? 1 : 0;
        animate opacity { duration: 150ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }
        width: self.dia;
        height: self.dia;
        x: root.outer-r - self.dia / 2;
        y: root.outer-r - self.dia / 2;
        border-radius: self.dia / 2;
        background: Skin.settings-btn;
        drop-shadow-color: #00000073;          // rgba(0,0,0,0.45)
        drop-shadow-blur: 16.8px * root.pop;   // shadowBlur 0.7 x blurMax 24
        drop-shadow-offset-y: 3px;
        Image {
            source: root.logo;
            width: parent.dia * 0.82;
            height: parent.dia * 0.82;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }

    // ---- 6. icon slots ----
    for item[i] in root.items: Rectangle {
        private property <float> hs: root.hovered-index == i ? 1.14 : 1.0;
        animate hs { duration: 150ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
        private property <float> k: root.pop * self.hs;   // slot content scale
        private property <angle> ang: -90deg + i * root.seg-ang;
        private property <length> box: root.icon-box * self.k;
        // window-count dots metrics
        private property <length> dot-d: Skin.s(5) * self.k;
        private property <length> dot-sp: Skin.s(3) * self.k;
        private property <length> row-w: item.dot-count * self.dot-d
            + Math.max(item.dot-count - 1, 0) * self.dot-sp;
        // icon image height (dots anchor below it)
        private property <length> img-h: root.icon-box * self.k - Skin.s(10) * self.k;

        width: self.box;
        height: self.box;
        x: root.outer-r + root.ring-r * root.pop * Math.cos(self.ang) - self.box / 2;
        y: root.outer-r + root.ring-r * root.pop * Math.sin(self.ang) - self.box / 2;

        // content priority: icon image -> nerd-font glyph -> monogram
        if item.has-icon: Image {
            source: item.icon;
            colorize: item.is-action && item.tint.alpha > 0 ? item.tint : transparent;
            width: parent.box - Skin.s(10) * parent.k;
            height: self.width;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
        if !item.has-icon && item.glyph != "": Text {
            text: item.glyph;
            font-family: Skin.icon-font;
            font-size: root.icon-box * 0.46 * parent.k;
            color: Skin.on-band;
            width: 100%;
            height: 100%;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        if !item.has-icon && item.glyph == "": Text {
            text: item.monogram;
            font-family: Skin.font-display;
            font-size: root.icon-box * 0.46 * parent.k;
            color: Skin.on-band;
            width: 100%;
            height: 100%;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        // window-count dots (already capped at 6 by Rust)
        for d in item.dot-count: Rectangle {
            visible: Skin.show-dots;
            private property <float> ds: d == item.sel-dot ? 1.2 : 1.0;
            animate ds { duration: 120ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
            width: parent.dot-d * self.ds;
            height: self.width;
            border-radius: self.width / 2;
            background: d == item.sel-dot ? (item.wedge.alpha > 0 ? item.wedge : Skin.accent) : Skin.dot;
            x: (parent.width - parent.row-w) / 2
                + d * (parent.dot-d + parent.dot-sp)
                + (parent.dot-d - self.width) / 2;
            y: parent.box / 2 + parent.img-h / 2 + Skin.s(2) * parent.k
                + (parent.dot-d - self.height) / 2;
        }
    }

    // ---- 7. center label pill (topmost) ----
    Rectangle {
        private property <float> ps: root.pill-on ? 1.0 : 0.85;
        animate ps { duration: 160ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
        private property <float> k: self.ps * root.pop;
        opacity: root.pill-on ? 1 : 0;
        animate opacity { duration: 130ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }
        visible: self.opacity > 0.001;
        width: ptxt.preferred-width + Skin.s(24) * self.k;
        height: ptxt.preferred-height + Skin.s(12) * self.k;
        border-radius: Skin.s(9) * self.k;
        background: Skin.label-pill-bg;
        x: root.outer-r - self.width / 2;
        y: root.outer-r
            + (root.actions-mode ? root.inner-r * 0.46 * root.pop : 0px)
            - self.height / 2;
        ptxt := Text {
            text: root.center-label;
            color: Skin.label-fg;
            font-family: Skin.font;
            font-size: Skin.s(14) * parent.k;
            font-weight: 500;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }
}

export component ActionArc {
    // Geometry from Rust (same center as the wheel).
    in property <length> arc-radius;     // button-center radius
    in property <length> btn-r;
    in property <length> band-inner;
    in property <length> band-outer;

    in property <[ArcItem]> items;
    in property <string> app-label;      // pill text fallback (hovered label wins)
    in property <bool> open;

    // Buttons are discrete circles -> they own their TouchAreas (they sit on
    // top of the fullscreen input layer in the window stacking order).
    callback action-clicked(int);

    width: 2 * root.band-outer;
    height: 2 * root.band-outer;
    visible: root.open || content.opacity > 0.001;   // alive during fade-out

    private property <int> n: root.items.length;
    private property <int> hov: -1;                  // hovered button index
    // pop-style open scale, applied to every drawn length (about the center)
    private property <float> apop: root.open ? 1.0 : 0.9;
    animate apop { duration: 180ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
    // buttons spread symmetrically about straight-up, 30deg pitch, 150deg cap
    private property <float> span: Math.min(150, 30 * Math.max(1, root.n));
    private property <float> cxf: root.band-outer / 1px;
    private property <float> fbo: root.band-outer / 1px * root.apop;
    private property <float> fbi: root.band-inner / 1px * root.apop;

    content := Rectangle {
        width: 100%;
        height: 100%;
        opacity: root.open ? 1 : 0;
        animate opacity { duration: 150ms; easing: cubic-bezier(0.33, 1, 0.68, 1); }

        // top half-annulus band (canvas angles pi -> 2pi, flat bottom edge)
        Path {
            width: 100%;
            height: 100%;
            viewbox-width: self.width / 1px;
            viewbox-height: self.height / 1px;
            fill: Skin.arc-bg;
            stroke: Skin.arc-stroke;
            stroke-width: 1px;
            MoveTo { x: root.cxf - root.fbo; y: root.cxf; }
            ArcTo { x: root.cxf + root.fbo; y: root.cxf; radius-x: root.fbo; radius-y: root.fbo; sweep: true; }
            LineTo { x: root.cxf + root.fbi; y: root.cxf; }
            ArcTo { x: root.cxf - root.fbi; y: root.cxf; radius-x: root.fbi; radius-y: root.fbi; sweep: false; }
            Close { }
        }

        // action buttons on the arc
        for item[i] in root.items: btn := Rectangle {
            private property <float> bs: bta.has-hover && root.open ? 1.12 : 1.0;
            animate bs { duration: 130ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
            private property <angle> ang: (180 + (180 - root.span) / 2
                + (root.n <= 1 ? root.span / 2 : i * root.span / (root.n - 1))) * 1deg;
            private property <length> dia: 2 * root.btn-r * root.apop * self.bs;

            width: self.dia;
            height: self.dia;
            x: root.band-outer + root.arc-radius * root.apop * Math.cos(self.ang) - self.dia / 2;
            y: root.band-outer + root.arc-radius * root.apop * Math.sin(self.ang) - self.dia / 2;
            border-radius: self.dia / 2;
            background: bta.has-hover && root.open ? Skin.arc-btn-hover : Skin.arc-btn;
            animate background { duration: 120ms; }

            bta := TouchArea {
                enabled: root.open;
                mouse-cursor: pointer;
                clicked => {
                    root.action-clicked(i);
                }
                changed has-hover => {
                    if (self.has-hover) {
                        root.hov = i;
                    } else if (root.hov == i) {
                        root.hov = -1;
                    }
                }
            }

            if item.has-icon: Image {
                source: item.icon;
                colorize: item.tint;         // Rust defaults tint to white
                width: root.btn-r * root.apop * btn.bs;
                height: self.width;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
            if !item.has-icon: Text {
                text: item.glyph;
                font-family: Skin.icon-font;
                font-size: Skin.s(18) * root.apop * btn.bs;
                color: item.tint;
                width: 100%;
                height: 100%;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // label pill above the arc: hovered action's label, else the app name
        Rectangle {
            width: atxt.preferred-width + Skin.s(22) * root.apop;
            height: atxt.preferred-height + Skin.s(10) * root.apop;
            border-radius: Skin.s(9) * root.apop;
            background: Skin.label-pill-bg;
            x: root.band-outer - self.width / 2;
            y: root.band-outer
                - (root.arc-radius + root.btn-r + Skin.s(8)) * root.apop
                - self.height;
            atxt := Text {
                text: root.hov >= 0 && root.hov < root.n ? root.items[root.hov].label : root.app-label;
                color: Skin.label-fg;
                font-family: Skin.font;
                font-size: Skin.s(13) * root.apop;
                font-weight: 500;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
    }
}
